<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="bp"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="pe.edu.upeu.controller.MainGuiController"
            style="-fx-background-color: #1a1f2e;">

    <top>
        <VBox>
            <!-- Barra de título superior -->
            <HBox style="-fx-background-color: #0f1520; -fx-padding: 10 20 10 20;"
                  alignment="CENTER_LEFT" spacing="14">
                <Label text="👕" style="-fx-font-size: 22;"/>
                <VBox spacing="1">
                    <Label text="SysVentas Polos"
                           style="-fx-text-fill: white; -fx-font-size: 15; -fx-font-weight: bold;"/>
                    <Label text="Sistema de Gestión de Ventas · UPEU"
                           style="-fx-text-fill: #4b5563; -fx-font-size: 10;"/>
                </VBox>
                <!-- Spacer -->
                <HBox HBox.hgrow="ALWAYS"/>
                <Label text="● En línea"
                       style="-fx-text-fill: #4ade80; -fx-font-size: 11;"/>
            </HBox>

            <!-- Línea azul decorativa -->
            <HBox style="-fx-background-color: #1a4a8a; -fx-min-height: 3; -fx-max-height: 3;"/>

            <!-- MenuBar -->
            <MenuBar fx:id="menuBarFx"
                     style="-fx-background-color: #111827;
                            -fx-padding: 2 8 2 8;
                            -fx-border-color: transparent transparent #2d3a52 transparent;">
            </MenuBar>
        </VBox>
    </top>

    <center>
        <TabPane fx:id="tabPaneFx"
                 tabClosingPolicy="SELECTED_TAB"
                 style="-fx-background-color: #1a1f2e;
                        -fx-tab-min-height: 34;
                        -fx-tab-max-height: 34;">
        </TabPane>
    </center>

    <bottom>
        <!-- Barra de estado inferior -->
        <HBox style="-fx-background-color: #0f1520;
                     -fx-padding: 5 16 5 16;
                     -fx-border-color: #2d3a52 transparent transparent transparent;"
              alignment="CENTER_LEFT" spacing="16">
            <Label text="© 2026 SysVentas · POO-G2 · UPEU"
                   style="-fx-text-fill: #374151; -fx-font-size: 10;"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Label text="Administrador"
                   style="-fx-text-fill: #4b5563; -fx-font-size: 10;"/>
        </HBox>
    </bottom>

</BorderPane>
