<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="0"
      style="-fx-background-color: #1a1f2e;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="pe.edu.upeu.controller.CategoriaController">

    <!-- Header -->
    <HBox style="-fx-background-color: #111827; -fx-padding: 16 24 16 24;" alignment="CENTER_LEFT" spacing="10">
        <Label text="🏷️" style="-fx-font-size: 20;"/>
        <VBox spacing="2">
            <Label text="Gestión de Categorías"
                   style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
            <Label text="Administra las categorías de productos"
                   style="-fx-text-fill: #6b7280; -fx-font-size: 11;"/>
        </VBox>
    </HBox>

    <!-- Separador azul -->
    <HBox style="-fx-background-color: #1a4a8a; -fx-min-height: 3; -fx-max-height: 3;"/>

    <!-- Contenido -->
    <VBox style="-fx-padding: 24;" spacing="20" VBox.vgrow="ALWAYS">

        <!-- Card formulario -->
        <VBox style="-fx-background-color: #1e2536;
                     -fx-background-radius: 8;
                     -fx-padding: 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 10, 0, 0, 4);"
              spacing="16">

            <Label text="DATOS DE CATEGORÍA"
                   style="-fx-text-fill: #93b4d9; -fx-font-size: 11; -fx-font-weight: bold;"/>

            <GridPane hgap="16" vgap="14">
                <columnConstraints>
                    <ColumnConstraints minWidth="110" prefWidth="110"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
                </columnConstraints>

                <Label text="ID Categoría:"
                       style="-fx-text-fill: #d1d5db; -fx-font-size: 13;"
                       GridPane.columnIndex="0" GridPane.rowIndex="0"
                       GridPane.valignment="CENTER"/>
                <TextField fx:id="txtIdCateg" promptText="Ej: C01"
                           style="-fx-background-color: #111827;
                                  -fx-text-fill: white;
                                  -fx-prompt-text-fill: #4b5563;
                                  -fx-border-color: #2d3a52;
                                  -fx-border-radius: 6;
                                  -fx-background-radius: 6;
                                  -fx-padding: 8 12 8 12;
                                  -fx-font-size: 13;"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Nombre:"
                       style="-fx-text-fill: #d1d5db; -fx-font-size: 13;"
                       GridPane.columnIndex="0" GridPane.rowIndex="1"
                       GridPane.valignment="CENTER"/>
                <TextField fx:id="txtNombre" promptText="Ej: Polos Casual"
                           style="-fx-background-color: #111827;
                                  -fx-text-fill: white;
                                  -fx-prompt-text-fill: #4b5563;
                                  -fx-border-color: #2d3a52;
                                  -fx-border-radius: 6;
                                  -fx-background-radius: 6;
                                  -fx-padding: 8 12 8 12;
                                  -fx-font-size: 13;"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            </GridPane>

            <!-- Botones -->
            <HBox spacing="10">
                <VBox.margin><Insets top="4.0"/></VBox.margin>
                <Button text="💾  Guardar" onAction="#guardar"
                        style="-fx-background-color: #1a4a8a;
                               -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-font-size: 13; -fx-background-radius: 6;
                               -fx-padding: 9 20 9 20; -fx-cursor: hand;"/>
                <Button text="🗑  Eliminar" onAction="#eliminar"
                        style="-fx-background-color: #7f1d1d;
                               -fx-text-fill: white; -fx-font-weight: bold;
                               -fx-font-size: 13; -fx-background-radius: 6;
                               -fx-padding: 9 20 9 20; -fx-cursor: hand;"/>
                <Button text="✖  Limpiar" onAction="#limpiar"
                        style="-fx-background-color: #2d3a52;
                               -fx-text-fill: #d1d5db; -fx-font-weight: bold;
                               -fx-font-size: 13; -fx-background-radius: 6;
                               -fx-padding: 9 20 9 20; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <!-- Card tabla -->
        <VBox style="-fx-background-color: #1e2536;
                     -fx-background-radius: 8;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 10, 0, 0, 4);"
              spacing="0" VBox.vgrow="ALWAYS">

            <HBox style="-fx-padding: 14 20 14 20; -fx-border-color: transparent transparent #2d3a52 transparent;">
                <Label text="LISTADO DE CATEGORÍAS"
                       style="-fx-text-fill: #93b4d9; -fx-font-size: 11; -fx-font-weight: bold;"/>
            </HBox>

            <TableView fx:id="tblCategoria" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white;
                              -fx-border-color: transparent;
                              -fx-table-cell-border-color: #e5e7eb;">
                <columns>
                    <TableColumn fx:id="colIdCateg" text="ID CATEGORÍA" prefWidth="150"
                                 style="-fx-text-fill: #1e2536;"/>
                    <TableColumn fx:id="colNombre" text="NOMBRE" prefWidth="300"
                                 style="-fx-text-fill: #1e2536;"/>
                </columns>
                <VBox.margin><Insets/></VBox.margin>
            </TableView>
        </VBox>

    </VBox>
</VBox>

