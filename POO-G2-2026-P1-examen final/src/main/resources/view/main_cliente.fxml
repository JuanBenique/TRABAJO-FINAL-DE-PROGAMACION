<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="0" style="-fx-background-color: #1a1f2e;" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="pe.edu.upeu.controller.ClienteController">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #111827; -fx-padding: 16 24 16 24;">
        <Label style="-fx-font-size: 20;" text="👤" />
        <VBox spacing="2">
            <Label style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;" text="Gestión de Clientes" />
            <Label style="-fx-text-fill: #6b7280; -fx-font-size: 11;" text="Registra y administra los clientes" />
        </VBox>
    </HBox>

    <!-- Separador azul -->
    <HBox style="-fx-background-color: #1a4a8a; -fx-min-height: 3; -fx-max-height: 3;" />

    <!-- Contenido -->
    <VBox spacing="20" style="-fx-padding: 24;" VBox.vgrow="ALWAYS">

        <!-- Card formulario -->
        <VBox spacing="16" style="-fx-background-color: #2a3550; -fx-background-radius: 8; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 10, 0, 0, 4);">

            <Label style="-fx-text-fill: #93b4d9; -fx-font-size: 11; -fx-font-weight: bold;" text="DATOS DEL CLIENTE" />

            <GridPane hgap="16" vgap="14">
                <columnConstraints>
                    <ColumnConstraints minWidth="110" prefWidth="110" />
                    <ColumnConstraints hgrow="ALWAYS" minWidth="200" />
                </columnConstraints>

                <!-- DNI -->
                <Label style="-fx-text-fill: #d1d5db; -fx-font-size: 13;" text="DNI:" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.valignment="CENTER" />
                <TextField fx:id="txtDni" promptText="Ej: 12345678" style="-fx-background-color: #111827;                                   -fx-text-fill: white;                                   -fx-prompt-text-fill: #4b5563;                                   -fx-border-color: #2d3a52;                                   -fx-border-radius: 6;                                   -fx-background-radius: 6;                                   -fx-padding: 8 12 8 12;                                   -fx-font-size: 13;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <!-- Nombre -->
                <Label style="-fx-text-fill: #d1d5db; -fx-font-size: 13;" text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.valignment="CENTER" />
                <TextField fx:id="txtNombre" promptText="Nombre completo" style="-fx-background-color: #111827;                                   -fx-text-fill: white;                                   -fx-prompt-text-fill: #4b5563;                                   -fx-border-color: #2d3a52;                                   -fx-border-radius: 6;                                   -fx-background-radius: 6;                                   -fx-padding: 8 12 8 12;                                   -fx-font-size: 13;" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <!-- Dirección -->
                <Label style="-fx-text-fill: #d1d5db; -fx-font-size: 13;" text="Dirección:" GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.valignment="CENTER" />
                <TextField fx:id="txtDireccion" promptText="Dirección" style="-fx-background-color: #111827;                                   -fx-text-fill: white;                                   -fx-prompt-text-fill: #4b5563;                                   -fx-border-color: #2d3a52;                                   -fx-border-radius: 6;                                   -fx-background-radius: 6;                                   -fx-padding: 8 12 8 12;                                   -fx-font-size: 13;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <!-- Celular -->
                <Label style="-fx-text-fill: #d1d5db; -fx-font-size: 13;" text="Celular:" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.valignment="CENTER" />
                <TextField fx:id="txtCelular" promptText="Ej: 987654321" style="-fx-background-color: #111827;                                   -fx-text-fill: white;                                   -fx-prompt-text-fill: #4b5563;                                   -fx-border-color: #2d3a52;                                   -fx-border-radius: 6;                                   -fx-background-radius: 6;                                   -fx-padding: 8 12 8 12;                                   -fx-font-size: 13;" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <rowConstraints>
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
            </rowConstraints>
            </GridPane>

            <!-- Botones -->
            <HBox spacing="10">
                <VBox.margin><Insets top="4.0" /></VBox.margin>
                <Button onAction="#guardar" style="-fx-background-color: #1a4a8a;                                -fx-text-fill: white;                                -fx-font-weight: bold;                                -fx-font-size: 13;                                -fx-background-radius: 6;                                -fx-padding: 9 20 9 20;                                -fx-cursor: hand;" text="💾  Guardar" />
                <Button onAction="#eliminar" style="-fx-background-color: #7f1d1d;                                -fx-text-fill: white;                                -fx-font-weight: bold;                                -fx-font-size: 13;                                -fx-background-radius: 6;                                -fx-padding: 9 20 9 20;                                -fx-cursor: hand;" text="🗑  Eliminar" />
                <Button onAction="#limpiar" style="-fx-background-color: #2d3a52;                                -fx-text-fill: #d1d5db;                                -fx-font-weight: bold;                                -fx-font-size: 13;                                -fx-background-radius: 6;                                -fx-padding: 9 20 9 20;                                -fx-cursor: hand;" text="✖  Limpiar" />
            </HBox>
        </VBox>

        <!-- Card tabla -->
        <VBox spacing="0" style="-fx-background-color: #1e2536;                      -fx-background-radius: 8;                      -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 10, 0, 0, 4);" VBox.vgrow="ALWAYS">

            <HBox style="-fx-padding: 14 20 14 20; -fx-border-color: transparent transparent #2d3a52 transparent;">
                <Label style="-fx-text-fill: #93b4d9; -fx-font-size: 11; -fx-font-weight: bold;" text="LISTADO DE CLIENTES" />
            </HBox>

            <TableView fx:id="tblCliente" style="-fx-background-color: #1e2536;                               -fx-border-color: transparent;                               -fx-table-cell-border-color: #2d3a52;" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colDni" prefWidth="120" text="DNI" />
                    <TableColumn fx:id="colNombre" prefWidth="200" text="NOMBRE" />
                    <TableColumn fx:id="colDireccion" prefWidth="200" text="DIRECCIÓN" />
                    <TableColumn fx:id="colCelular" prefWidth="130" text="CELULAR" />
                </columns>
            </TableView>
        </VBox>

    </VBox>
</VBox>
