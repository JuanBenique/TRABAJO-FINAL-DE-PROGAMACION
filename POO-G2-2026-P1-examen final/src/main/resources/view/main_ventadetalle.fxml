<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" style="-fx-padding: 20;" xmlns:fx="http://javafx.com/fxml"
      fx:controller="pe.edu.upeu.controller.VentaDetalleController">

    <Label text="Gestión de Detalle de Venta" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <Label text="ID Detalle:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="txtIdDetalle" promptText="Ej: DV0001" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Venta:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <ComboBox fx:id="cmbVenta" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Producto:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <ComboBox fx:id="cmbProducto" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Precio Unitario:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="txtPrecioUni" promptText="0.00" editable="false"
                   style="-fx-background-color: #f5f5f5;"
                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Porcentaje Utilidad:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="txtPorceUtil" promptText="0.00" editable="false"
                   style="-fx-background-color: #f5f5f5;"
                   GridPane.columnIndex="1" GridPane.rowIndex="4"/>

        <Label text="Cantidad:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <TextField fx:id="txtCantidad" promptText="Ej: 5" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

        <Label text="Neto Total:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
        <TextField fx:id="txtNetoTotal" promptText="0.00" editable="false"
                   style="-fx-background-color: #f5f5f5;"
                   GridPane.columnIndex="1" GridPane.rowIndex="6"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Guardar" onAction="#guardar" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
        <Button text="Eliminar" onAction="#eliminar" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
        <Button text="Limpiar" onAction="#limpiar"/>
    </HBox>

    <TableView fx:id="tblDetalle" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colIdDetalle" text="ID Detalle" prefWidth="90"/>
            <TableColumn fx:id="colVenta" text="Venta" prefWidth="80"/>
            <TableColumn fx:id="colProducto" text="Producto" prefWidth="150"/>
            <TableColumn fx:id="colPrecioUni" text="Precio Uni." prefWidth="90"/>
            <TableColumn fx:id="colPorceUtil" text="Porc.Util." prefWidth="70"/>
            <TableColumn fx:id="colCantidad" text="Cantidad" prefWidth="80"/>
            <TableColumn fx:id="colNetoTotal" text="Neto Total" prefWidth="90"/>
        </columns>
    </TableView>
</VBox>

